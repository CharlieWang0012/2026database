rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 你的第一個集合：任何人可讀寫（課堂 demo 用）
    match /2026/{document} {
      allow read, write: if true;
    }

    // 郵政甄試刷題統計：可讀取＋可新增，不可修改/刪除
    match /post_quiz_results/{document} {
      allow read: if true;
      allow create: if request.resource.data.nick is string
                    && request.resource.data.nick.size() > 0
                    && request.resource.data.nick.size() <= 40
                    && request.resource.data.total is int
                    && request.resource.data.correct is int;
      allow update, delete: if false;
    }

    // 🪞 鏡中人啟發收件匣：手機捕捉頁只能「新增」，外人不可讀/改/刪。
    // 內容由 Claude 用管理權限（後端）讀取後收進 Obsidian，再標記 processed。
    match /sparks/{document} {
      allow create: if request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 5000;
      allow read, update, delete: if false;
    }

    // 其他集合預設禁止存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
